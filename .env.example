# ============================================================
# DATABASE - Neon Tech PostgreSQL
# ============================================================

# URL dành cho Prisma Migrate & Prisma Studio (direct connection - không qua pooler)
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"

# URL dành cho runtime (qua Neon Serverless Pooler - PgBouncer mode)
# Thêm ?pgbouncer=true&connection_limit=1 để tránh cạn kiệt connection trên Vercel Serverless
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-xxx-pooler.ap-southeast-1.aws.neon.tech/neondb?pgbouncer=true&connection_limit=1&sslmode=require"

# ============================================================
# SERVER
# ============================================================
PORT=3000
NODE_ENV=development

# ============================================================
# AUTH
# ============================================================
JWT_SECRET="replace_this_with_a_strong_secret"
JWT_EXPIRES_IN=7d
MOMO_NOTIFY_URL="http://localhost:4000/api/payment/momo/ipn"  # IPN webhook
MOMO_RETURN_URL="http://localhost:3000/payment/momo/result"  # Return page
MOMO_ENABLED=true

# ============================================================
# MOMO BOOKING DEPOSIT (API v2 Sandbox)
# ============================================================
MOMO_ENDPOINT="https://test-payment.momo.vn/v2/gateway/api/create"
MOMO_PARTNER_CODE="YOUR_MOMO_PARTNER_CODE"
MOMO_ACCESS_KEY="YOUR_MOMO_ACCESS_KEY"
MOMO_SECRET_KEY="YOUR_MOMO_SECRET_KEY"

# Public base URLs used to compose callback destinations
BACKEND_BASE_URL="http://localhost:3000"
FRONTEND_BASE_URL="http://localhost:3000"

# Explicit callback URLs (override when backend/frontend use different domains)
MOMO_BOOKING_IPN_URL="http://localhost:3000/api/bookings/momo-ipn"
MOMO_BOOKING_REDIRECT_URL="http://localhost:3000/api/bookings/momo-callback"
BOOKING_RESULT_URL="http://localhost:3000/booking/result"
